ITE_BUERF_PARAMETER|BMD_YEAR|BMD_ZIPFILE)\\b"
        },
        {
          "name": "support.class.bmdmacro",
          "match": "(?i)\\b(MacroObject|CRMMacroObject|FibuMacroObject|WwsPpsMacroClasses)\\b"
        },
        {
          "name": "support.function.method.bmdmacro",
          "match": "\\.([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.bmdmacro",
          "match": ":="
        },
        {
          "name": "keyword.operator.comparison.bmdmacro",
          "match": "(<>|<=|>=|<|>|=)"
        },
        {
          "name": "keyword.operator.arithmetic.bmdmacro",
          "match": "(\\+|-|\\*|/)"
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.bmdmacro",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    }
  }
