{  
  "name": "BMD Macro",
  "scopeName": "source.bmdmacro",
  "fileTypes": [
    "mac",
    "macro"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#bmd-functions"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.bmdmacro",
          "match": "//.*$"
        },
        {
          "name": "comment.block.bmdmacro",
          "begin": "\\{",
          "end": "\\}"
        },
        {
          "name": "comment.block.bmdmacro",
          "begin": "\\(\\*",
          "end": "\\*\\)"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.single.bmdmacro",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.bmdmacro",
          "match": "''"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.bmdmacro",
          "match": "(?i)\\b(begin|end|if|then|else|while|do|for|to|downto|repeat|until|case|of|break|continue|exit)\\b"
        },
        {
          "name": "keyword.declaration.bmdmacro",
          "match": "(?i)\\b(var|const|procedure|function|program)\\b"
        },
        {
          "name": "keyword.other.bmdmacro",
          "match": "(?i)\\b(and|or|not|mod|div|xor|in|is)\\b"
        },
        {
          "name": "storage.type.bmdmacro",
          "match": "(?i)\\b(integer|string|boolean|real|float|date|datetime|variant|array)\\b"
        },
        {
          "name": "constant.language.bmdmacro",
          "match": "(?i)\\b(true|false|nil)\\b"
        }
      ]
    },    
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.bmdmacro",
          "match": ":="
        },
        {
          "name": "keyword.operator.comparison.bmdmacro",
          "match": "(<>|<=|>=|<|>|=)"
        },
        {
          "name": "keyword.operator.arithmetic.bmdmacro",
          "match": "(\\+|-|\\*|/)"
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.bmdmacro",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    }
  }
}